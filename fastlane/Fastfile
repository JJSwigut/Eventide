default_platform(:android)

def env_or_default(name, default)
  value = ENV[name].to_s.strip
  value.empty? ? default : value
end

def google_play_json_key_data
  json_key_data = ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"].to_s
  json_key_data = ENV["SUPPLY_JSON_KEY_DATA"].to_s if json_key_data.empty?
  UI.user_error!("Set GOOGLE_PLAY_SERVICE_ACCOUNT_JSON to the Google Play service-account JSON.") if json_key_data.empty?
  json_key_data
end

platform :android do
  desc "Build a signed release Android App Bundle"
  lane :build_release do |options|
    properties = {}
    version_code = options[:version_code] || ENV["VERSION_CODE"]
    properties["overrideVersionCode"] = version_code unless version_code.to_s.empty?

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: ".",
      properties: properties
    )
  end

  desc "Upload a signed release Android App Bundle to Google Play"
  lane :deploy do |options|
    repo_root = File.expand_path("..", __dir__)
    aab = options[:aab].to_s
    aab = ENV["AAB_PATH"].to_s if aab.empty?
    aab = Dir[File.join(repo_root, "app/build/outputs/bundle/release/*.aab")].max_by { |path| File.mtime(path) } if aab.empty?
    aab = File.expand_path(aab, repo_root) unless aab.empty? || aab.start_with?("/")
    UI.user_error!("No release AAB found. Build :app:bundleRelease first or pass aab:/path/to/app.aab.") unless aab && File.exist?(aab)

    upload_to_play_store(
      package_name: "com.jjswigut.eventide",
      aab: aab,
      json_key_data: google_play_json_key_data,
      track: env_or_default("PLAY_TRACK", "internal"),
      release_status: env_or_default("PLAY_RELEASE_STATUS", "completed"),
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Validate or publish the Google Play store listing"
  lane :store_listing do |options|
    repo_root = File.expand_path("..", __dir__)
    validate_only = options.fetch(:validate_only, true).to_s.downcase != "false"

    upload_to_play_store(
      package_name: "com.jjswigut.eventide",
      json_key_data: google_play_json_key_data,
      metadata_path: File.join(repo_root, "fastlane/metadata/android"),
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_changelogs: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      sync_image_upload: true,
      validate_only: validate_only
    )
  end
end
